{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "instructions": ["AGENTS.md", "CLAUDE.md"],

  "skills": {
    "paths": [".opencode/skills"]
  },

  "mcp": {
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true
    },
    "pencil": {
      "type": "local",
      "command": ["c:\\Users\\zjp\\.vscode\\extensions\\highagency.pencildev-0.6.51\\out\\mcp-server-windows-x64.exe", "--app", "visual_studio_code", "--agent", "openCodeCLI"],
      "enabled": true
    }
  },

  "permission": {
    "edit": "allow",
    "bash": {
      "pytest *": "allow",
      "python main.py --health": "allow",
      "python -m pytest *": "allow",
      "git status": "allow",
      "git diff": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "*": "ask"
    },
    "external_directory": {
      "C:\\Users\\zjp\\AppData\\Local\\Temp\\opencode\\*": "allow",
      "C:\\Users\\zjp\\.local\\share\\opencode\\tool-output\\*": "allow",
      "*": "ask"
    }
  },

  "agent": {
    "build": {
      "disable": false
    }
  }
}
